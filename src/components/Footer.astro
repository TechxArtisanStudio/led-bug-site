---
import { SHOP_URL } from '../lib/cdn';
---

<footer class="border-t border-white/10 bg-bg px-4 py-12 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div class="led-divider mb-10 max-w-md"></div>

    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-3">
      <div>
        <h2 class="font-mono text-xs uppercase tracking-widest text-cyan-400/80">LED-Bug</h2>
        <p class="mt-3 max-w-xs text-sm leading-relaxed text-white/60">
          Creative LED control for installations and makers. A product by TechxArtisan.
        </p>
      </div>

      <div>
        <h2 class="font-mono text-xs uppercase tracking-widest text-white/40">Connect</h2>
        <ul class="mt-3 space-y-2 text-sm">
          <li>
            <a
              href="https://github.com/TechxArtisan"
              class="text-white/70 hover:text-cyan-400"
              target="_blank"
              rel="noopener noreferrer"
            >
              GitHub
            </a>
          </li>
          <li>
            <a
              href="https://youtube.com/@TechxArtisan"
              class="text-white/70 hover:text-cyan-400"
              target="_blank"
              rel="noopener noreferrer"
            >
              YouTube
            </a>
          </li>
          <li>
            <a
              href="https://techxartisan.com/en/"
              class="text-white/70 hover:text-cyan-400"
              target="_blank"
              rel="noopener noreferrer"
            >
              TechxArtisan
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h2 class="font-mono text-xs uppercase tracking-widest text-white/40">Order</h2>
        <a
          href={SHOP_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-3 inline-block rounded-full bg-accent px-5 py-2 text-sm font-medium text-white transition hover:bg-accent/90"
        >
          Shop now
        </a>
      </div>
    </div>

    <div class="mt-12 space-y-2 text-center font-mono text-xs text-white/30">
      <p>© {new Date().getFullYear()} TechxArtisan · LED-Bug</p>
      <p class="text-white/25">
        广州比利奥科技有限公司 ·
        <a
          href="https://beian.miit.gov.cn"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-white/45"
        >
          粤ICP备2022069650号-2
        </a>
      </p>
      <p>
        <button
          type="button"
          id="cookie-settings-link"
          class="text-white/25 underline decoration-white/15 underline-offset-2 transition hover:text-white/45"
        >
          Cookie settings
        </button>
        ·
        <a href="mailto:info@techxartisan.com" class="text-white/25 hover:text-white/45">
          Contact
        </a>
      </p>
    </div>
  </div>
</footer>

<script is:inline>
  document.getElementById('cookie-settings-link')?.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('open-cookie-consent'));
  });
</script>
