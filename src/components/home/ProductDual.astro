---
import { ASSETS, SHOP_URL } from '../../lib/cdn';
import { getMessages } from '../../lib/i18n';
import { getLocaleFromPath } from '../../lib/locale-from-path';
import { localePath } from '../../i18n/locales';

const locale = getLocaleFromPath(Astro.url.pathname);
const m = await getMessages(locale);
const h = m.home;
const lp = (p: string) => localePath(locale, p);
---

<section id="products" class="px-4 py-20 sm:px-6 sm:py-28 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div class="reveal mb-10 text-center sm:mb-14">
      <p class="font-mono text-xs uppercase tracking-widest text-accent/90">{h.hardwareLabel}</p>
      <h2 class="mt-2 text-3xl font-bold text-white sm:text-4xl">{h.hardwareTitle}</h2>
    </div>

    <div class="reveal grid gap-4 lg:grid-cols-2 lg:gap-6" style="transition-delay: 0.1s">
      <article
        class="product-panel group rounded-2xl border border-white/10 bg-surface p-6 transition hover:border-accent/50 sm:p-8"
      >
        <div class="flex flex-col gap-6 sm:flex-row">
          <div class="shrink-0 overflow-hidden rounded-xl bg-black/30 sm:w-44">
            <img
              src={ASSETS.sr.hero}
              alt={h.srAlt}
              class="aspect-square w-full object-contain p-4 transition group-hover:scale-105"
              loading="lazy"
            />
          </div>
          <div class="min-w-0 flex-1">
            <h3 class="text-2xl font-bold text-white">{h.srName}</h3>
            <p class="mt-2 text-sm text-white/60">{h.srBlurb}</p>
            <ul class="mt-4 space-y-1 font-mono text-xs text-white/45">
              {h.srBullets.map((line) => <li>{line}</li>)}
            </ul>
            <a
              href={lp('/products/led-bug-sr')}
              class="mt-5 inline-block text-sm font-medium text-accent hover:text-accent/80"
            >
              {h.srFullSpecs}
            </a>
          </div>
        </div>
        <div class="mt-6 flex gap-2 overflow-x-auto hide-scrollbar">
          {
            ASSETS.sr.intros.map((src) => (
              <img
                src={src}
                alt=""
                class="h-16 w-auto shrink-0 rounded-lg border border-white/10 object-cover sm:h-20"
                loading="lazy"
              />
            ))
          }
        </div>
      </article>

      <article
        class="product-panel group rounded-2xl border border-white/10 bg-surface p-6 transition hover:border-cyan-400/50 sm:p-8"
      >
        <div class="flex flex-col gap-6 sm:flex-row">
          <div class="shrink-0 overflow-hidden rounded-xl bg-black/30 sm:w-44">
            <img
              src={ASSETS.mini.hero}
              alt={h.miniAlt}
              class="aspect-square w-full object-contain p-4 transition group-hover:scale-105"
              loading="lazy"
            />
          </div>
          <div class="min-w-0 flex-1">
            <h3 class="text-2xl font-bold text-white">{h.miniName}</h3>
            <p class="mt-2 text-sm text-white/60">{h.miniBlurb}</p>
            <ul class="mt-4 space-y-1 font-mono text-xs text-white/45">
              {h.miniBullets.map((line) => <li>{line}</li>)}
            </ul>
            <a
              href={lp('/products/led-bug-mini')}
              class="mt-5 inline-block text-sm font-medium text-cyan-400 hover:text-cyan-300"
            >
              {h.miniFullSpecs}
            </a>
          </div>
        </div>
        <div class="mt-6 flex gap-2 overflow-x-auto hide-scrollbar">
          {
            ASSETS.mini.intros.map((src) => (
              <img
                src={src}
                alt=""
                class="h-16 w-auto shrink-0 rounded-lg border border-white/10 object-cover sm:h-20"
                loading="lazy"
              />
            ))
          }
        </div>
      </article>
    </div>

    <div class="reveal mt-10 text-center" style="transition-delay: 0.2s">
      <a
        href={SHOP_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex rounded-full bg-accent px-8 py-3.5 text-sm font-semibold text-white transition hover:bg-accent/90"
      >
        {m.footer.shopNow}
      </a>
    </div>
  </div>
</section>
