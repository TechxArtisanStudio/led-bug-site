---
import { getProjects } from '../../data/projects';
import { getMessages } from '../../lib/i18n';
import { getLocaleFromPath } from '../../lib/locale-from-path';
import { localePath } from '../../i18n/locales';
import GlowCard from './GlowCard.astro';

const locale = getLocaleFromPath(Astro.url.pathname);
const m = await getMessages(locale);
const projects = await getProjects(locale);
const lp = (p: string) => localePath(locale, p);

const featuredSlug = 'coloured-towers';
const featured = projects.find((p) => p.slug === featuredSlug) ?? projects[0];
if (!featured) {
  return null;
}
const rest = projects.filter((p) => p.slug !== featured.slug);
const bento = [featured, ...rest];
const [bentoFeatured, ...bentoRest] = bento;
const h = m.home;
---

<section id="work" class="px-4 py-20 sm:px-6 sm:py-28 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div class="reveal mb-10 flex flex-col gap-4 sm:mb-14 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="font-mono text-xs uppercase tracking-widest text-cyan-400/80">{h.installationsLabel}</p>
        <h2 class="mt-2 text-3xl font-bold text-white sm:text-4xl">{h.installationsTitle}</h2>
      </div>
      <a
        href={lp('/projects')}
        class="text-sm font-medium text-white/60 transition hover:text-cyan-400"
      >
        {h.viewAllProjects}
      </a>
    </div>

    <div
      class="reveal hidden gap-4 lg:grid lg:grid-cols-4 lg:grid-rows-2 lg:gap-4"
      style="transition-delay: 0.1s"
    >
      <GlowCard
        href={`${lp('/projects')}/${bentoFeatured.slug}`}
        title={bentoFeatured.title}
        tag={bentoFeatured.tag}
        cover={bentoFeatured.cover}
        accent={bentoFeatured.accent}
        summary={bentoFeatured.summary}
        featured
        class="lg:col-span-2 lg:row-span-2"
      />
      {
        bentoRest.slice(0, 2).map((p) => (
          <GlowCard
            href={`${lp('/projects')}/${p.slug}`}
            title={p.title}
            tag={p.tag}
            cover={p.cover}
            accent={p.accent}
            summary={p.summary}
          />
        ))
      }
      {
        bentoRest.slice(2, 5).map((p) => (
          <GlowCard
            href={`${lp('/projects')}/${p.slug}`}
            title={p.title}
            tag={p.tag}
            cover={p.cover}
            accent={p.accent}
            summary={p.summary}
            class="lg:col-span-1"
          />
        ))
      }
    </div>

    <div
      class="reveal flex gap-4 overflow-x-auto pb-4 hide-scrollbar lg:hidden snap-x snap-mandatory"
      style="transition-delay: 0.1s"
    >
      {
        bento.map((p) => (
          <div class="w-[min(85vw,320px)] shrink-0 snap-center">
            <GlowCard
              href={`${lp('/projects')}/${p.slug}`}
              title={p.title}
              tag={p.tag}
              cover={p.cover}
              accent={p.accent}
              summary={p.summary}
              class="h-[280px]"
            />
          </div>
        ))
      }
    </div>
  </div>
</section>
