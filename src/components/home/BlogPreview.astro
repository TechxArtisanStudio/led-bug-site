---
import PostCard from '../blog/PostCard.astro';
import { getCollection } from 'astro:content';
import { postSlug } from '../../lib/posts';

const posts = (await getCollection('posts'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 2);
---

<section class="px-4 py-20 sm:px-6 sm:py-28 lg:px-8">
  <div class="mx-auto max-w-5xl">
    <div class="reveal flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="font-mono text-xs uppercase tracking-widest text-white/40">From the blog</p>
        <h2 class="mt-2 text-3xl font-bold text-white sm:text-4xl">Stories &amp; deep dives</h2>
      </div>
      <a
        href="/blog"
        class="font-mono text-sm text-cyan-400/90 transition hover:text-cyan-300"
      >
        View all →
      </a>
    </div>

    <div class="reveal mt-10 grid gap-6 sm:grid-cols-2" style="transition-delay: 0.1s">
      {
        posts.map((post) => (
          <PostCard
            slug={postSlug(post)}
            title={post.data.title}
            subtitle={post.data.subtitle}
            description={post.data.description}
            cover={post.data.cover}
            date={post.data.date}
            categories={post.data.categories}
          />
        ))
      }
    </div>
  </div>
</section>
