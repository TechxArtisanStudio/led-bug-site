---
import PostCard from '../blog/PostCard.astro';
import { getCollection } from 'astro:content';
import { postSlug, postsForLocale } from '../../lib/posts';
import { getMessages } from '../../lib/i18n';
import { getLocaleFromPath } from '../../lib/locale-from-path';
import { localePath } from '../../i18n/locales';

const locale = getLocaleFromPath(Astro.url.pathname);
const m = await getMessages(locale);
const h = m.home;
const lp = (p: string) => localePath(locale, p);

const allPosts = await getCollection('posts');
const posts = postsForLocale(allPosts, locale)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 2);
---

<section class="px-4 py-20 sm:px-6 sm:py-28 lg:px-8">
  <div class="mx-auto max-w-5xl">
    <div class="reveal flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="font-mono text-xs uppercase tracking-widest text-white/40">{h.blogLabel}</p>
        <h2 class="mt-2 text-3xl font-bold text-white sm:text-4xl">{h.blogTitle}</h2>
      </div>
      <a
        href={lp('/blog')}
        class="font-mono text-sm text-cyan-400/90 transition hover:text-cyan-300"
      >
        {h.viewAllBlog}
      </a>
    </div>

    <div class="reveal mt-10 grid gap-6 sm:grid-cols-2" style="transition-delay: 0.1s">
      {
        posts.map((post) => (
          <PostCard
            slug={postSlug(post)}
            title={post.data.title}
            subtitle={post.data.subtitle}
            description={post.data.description}
            cover={post.data.cover}
            date={post.data.date}
            categories={post.data.categories}
          />
        ))
      }
    </div>
  </div>
</section>
