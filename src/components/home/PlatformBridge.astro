---
import { img } from '../../lib/cdn';
import { getMessages } from '../../lib/i18n';
import { getLocaleFromPath } from '../../lib/locale-from-path';

const locale = getLocaleFromPath(Astro.url.pathname);
const m = await getMessages(locale);
const h = m.home;

const stills = [
  img('projects/mechanical-tree/02.webp'),
  img('projects/moon-river/01.webp'),
  img('projects/led-bug-demos/cover.webp'),
];
---

<section class="relative overflow-hidden bg-surface px-4 py-20 sm:px-6 sm:py-28 lg:px-8">
  <div class="scanlines pointer-events-none absolute inset-0"></div>

  <div class="relative mx-auto max-w-7xl">
    <div class="reveal max-w-2xl">
      <p class="font-mono text-xs uppercase tracking-widest text-white/40">{h.platformLabel}</p>
      <h2 class="mt-2 text-3xl font-bold leading-tight text-white sm:text-4xl">
        {h.platformTitle}
      </h2>
      <p class="mt-5 text-base leading-relaxed text-white/65 sm:text-lg">
        {h.platformBody}
      </p>
      <div class="mt-8 flex flex-wrap gap-2">
        {
          h.chips.map((chip) => (
            <span class="rounded-full border border-cyan-500/30 bg-cyan-500/5 px-4 py-2 font-mono text-xs text-cyan-300/90 transition hover:border-cyan-400/60 hover:bg-cyan-500/10">
              {chip}
            </span>
          ))
        }
      </div>
    </div>

    <div class="reveal mt-12 flex gap-4 overflow-x-auto hide-scrollbar sm:mt-16 lg:gap-6" style="transition-delay: 0.15s">
      {
        stills.map((src) => (
          <div class="group relative min-w-[240px] flex-1 overflow-hidden rounded-xl sm:min-w-0">
            <img
              src={src}
              alt=""
              class="aspect-[4/3] h-full w-full object-cover transition duration-700 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 ring-1 ring-inset ring-white/10 rounded-xl"></div>
          </div>
        ))
      }
    </div>
  </div>
</section>
