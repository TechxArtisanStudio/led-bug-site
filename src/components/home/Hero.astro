---
import { ASSETS } from '../../lib/cdn';
import LedGrid from '../LedGrid';
---

<section class="relative flex min-h-[100dvh] items-center overflow-hidden pt-14 lg:items-end sm:pt-16">
  <div class="absolute inset-0">
    <img
      src={ASSETS.heroPoster}
      alt=""
      class="h-full w-full object-cover"
      fetchpriority="high"
    />
    <video
      id="hero-video"
      class="absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-1000"
      muted
      loop
      playsinline
      preload="none"
      poster={ASSETS.heroPoster}
    >
      <source src={ASSETS.heroVideo} type="video/mp4" />
    </video>
    <div
      class="absolute inset-0 bg-gradient-to-b from-bg/60 via-bg/75 to-bg"
    >
    </div>
    <div
      class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_center,transparent_0%,#0a0a0f_75%)]"
    >
    </div>
  </div>

  <LedGrid client:media="(min-width: 768px) and (prefers-reduced-motion: no-preference)" />

  <div class="relative z-10 mx-auto w-full max-w-7xl px-4 py-10 sm:px-6 lg:px-8 lg:pb-24 lg:pt-32 [&_h1]:drop-shadow-[0_2px_24px_rgba(0,0,0,0.9)] [&_p]:drop-shadow-[0_2px_16px_rgba(0,0,0,0.8)]">
    <p
      class="reveal reveal-on-load font-mono text-xs uppercase tracking-[0.25em] text-cyan-400/90 sm:text-sm"
    >
      WLED · DMX512 · ESP32
    </p>
    <h1
      class="reveal reveal-on-load mt-4 max-w-3xl text-3xl font-bold leading-[1.08] tracking-tight text-white sm:text-5xl lg:text-6xl"
      style="transition-delay: 0.1s"
    >
      Creative LED control for installations &amp; makers
    </h1>
    <p
      class="reveal reveal-on-load mt-5 max-w-xl text-base leading-relaxed text-white/65 sm:text-lg"
      style="transition-delay: 0.2s"
    >
      From gallery-scale robotics to desk prototypes — one controller platform that runs WLED out of
      the box and opens up when you need custom code.
    </p>
    <div
      class="reveal reveal-on-load mt-8 flex flex-col gap-3 sm:flex-row sm:items-center"
      style="transition-delay: 0.3s"
    >
      <a
        href="#work"
        class="inline-flex items-center justify-center rounded-full bg-accent px-6 py-3 text-sm font-semibold text-white transition hover:bg-accent/90"
      >
        See our work
      </a>
      <a
        href="#products"
        class="inline-flex items-center justify-center rounded-full border border-white/20 px-6 py-3 text-sm font-medium text-white/90 transition hover:border-cyan-400/50 hover:text-cyan-400"
      >
        Explore controllers
      </a>
    </div>
  </div>

  <a
    href="#work"
    class="absolute bottom-6 left-1/2 z-10 -translate-x-1/2 text-white/40 transition hover:text-cyan-400"
    aria-label="Scroll to work"
  >
    <svg
      class="chevron-pulse h-6 w-6"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
    </svg>
  </a>
</section>

<script>
  const video = document.getElementById('hero-video') as HTMLVideoElement | null;
  if (video && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const play = () => {
      video.classList.remove('opacity-0');
      video.classList.add('opacity-100');
      video.play().catch(() => {});
    };
    if ('requestIdleCallback' in window) {
      requestIdleCallback(() => {
        video.load();
        play();
      });
    } else {
      setTimeout(() => {
        video.load();
        play();
      }, 500);
    }
  }
</script>
