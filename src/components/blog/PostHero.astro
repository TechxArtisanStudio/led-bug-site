---
import { getLocaleFromPath } from '../../lib/locale-from-path';
import { getMessages } from '../../lib/i18n';
import { formatBlogDate } from '../../lib/format-date';

interface Props {
  title: string;
  subtitle: string;
  date: Date;
  authors: string[];
  categories: string[];
  cover: string;
  series?: string;
  part?: number;
}

const { title, subtitle, date, authors, categories, cover, series, part } = Astro.props;
const locale = getLocaleFromPath(Astro.url.pathname);
const m = await getMessages(locale);
const formattedDate = formatBlogDate(date, locale, 'long');

const seriesLabel =
  series && part
    ? m.blog.seriesPart
        .replace('{series}', series.replace(/-/g, ' '))
        .replace('{part}', String(part))
        .replace('{total}', '2')
    : null;
---

<header class="relative overflow-hidden border-b border-white/10">
  <div class="absolute inset-0">
    <img
      src={cover}
      alt=""
      class="h-full w-full object-cover opacity-40"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-bg via-bg/90 to-bg/60"></div>
  </div>

  <div class="relative blog-body-shell pb-12 pt-28 sm:pb-16 sm:pt-32">
    <div class="blog-read-column">
    {
      seriesLabel && (
        <p class="font-mono text-xs uppercase tracking-widest text-cyan-400/90">
          {seriesLabel}
        </p>
      )
    }
    <h1 class="mt-3 text-3xl font-bold leading-tight text-white sm:text-4xl lg:text-5xl">
      {title}
    </h1>
    <p class="mt-2 text-lg text-white/70 sm:text-xl">{subtitle}</p>

    <div class="mt-6 flex flex-wrap items-center gap-x-4 gap-y-2 font-mono text-xs text-white/45">
      <time datetime={date.toISOString()}>{formattedDate}</time>
      <span>·</span>
      <span>{authors.join(', ')}</span>
      {
        categories.map((cat) => (
          <span class="rounded-full border border-white/15 px-2 py-0.5 text-cyan-400/80">
            {cat}
          </span>
        ))
      }
    </div>
    </div>
  </div>
</header>
