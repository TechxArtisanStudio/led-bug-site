---
interface Props {
  src: string;
  alt: string;
  caption?: string;
  size?: 'landscape' | 'portrait' | 'banner' | 'landscape-wide' | 'wide';
}

const { src, alt, caption, size = 'landscape' } = Astro.props;

const sizeClass =
  size === 'wide'
    ? 'post-figure--wide'
    : size === 'portrait'
      ? 'post-figure--portrait'
      : size === 'banner'
        ? 'post-figure--banner'
        : size === 'landscape-wide'
          ? 'post-figure--landscape-wide'
          : 'post-figure--landscape';
---

<figure class:list={['post-figure', sizeClass]}>
  <div class="post-figure-media">
    <img
      src={src}
      alt={alt}
      loading="lazy"
      decoding="async"
      class="post-figure-img"
    />
  </div>
  {caption && <figcaption class="post-figure-caption">{caption}</figcaption>}
</figure>
