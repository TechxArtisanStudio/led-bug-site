---
import { ASSETS, SHOP_URL } from '../lib/cdn';
import { getMessages } from '../lib/i18n';
import { getLocaleFromPath } from '../lib/locale-from-path';
import { localePath } from '../i18n/locales';
import LanguageSwitcher from './LanguageSwitcher.astro';

const locale = getLocaleFromPath(Astro.url.pathname);
const m = await getMessages(locale);
const lp = (p: string) => localePath(locale, p);

const links = [
  { href: `${lp('/')}#work`, label: m.nav.work },
  { href: `${lp('/')}#products`, label: m.nav.products },
  { href: lp('/projects'), label: m.nav.projects },
  { href: lp('/blog'), label: m.nav.blog },
  { href: lp('/about'), label: m.nav.about },
];
---

<header
  class="fixed top-0 z-50 w-full border-b border-cyan-500/20 bg-bg/80 backdrop-blur-md"
>
  <div class="site-container site-gutter flex h-14 items-center justify-between sm:h-16">
    <a href={lp('/')} class="flex items-center gap-2 shrink-0">
      <img
        src={ASSETS.logo}
        alt="LED-Bug"
        class="h-7 w-auto sm:h-8"
        width="120"
        height="32"
        loading="eager"
      />
    </a>

    <nav class="hidden items-center gap-6 md:flex" aria-label={m.nav.mainAriaLabel}>
      {
        links.map((link) => (
          <a
            href={link.href}
            class="text-sm font-medium text-white/70 transition hover:text-cyan-400"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="flex shrink-0 items-center gap-2 sm:gap-3">
      <div class="hidden md:block">
        <LanguageSwitcher languageLabel={m.nav.language} />
      </div>
      <a
        href={SHOP_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden rounded-full border border-accent/60 bg-accent/10 px-4 py-1.5 text-xs font-medium text-accent transition hover:bg-accent hover:text-white md:inline-flex"
      >
        {m.nav.shop}
      </a>

      <details class="relative md:hidden">
        <summary
          class="list-none cursor-pointer rounded-lg border border-white/10 px-3 py-2 text-sm text-white/80 [&::-webkit-details-marker]:hidden"
        >
          {m.nav.menu}
        </summary>
        <div
          class="absolute right-0 mt-2 w-56 rounded-xl border border-white/10 bg-surface p-2 shadow-xl"
        >
          <div class="flex flex-col gap-0.5">
            {
              links.map((link) => (
                <a
                  href={link.href}
                  class="block rounded-lg px-3 py-2 text-sm text-white/80 hover:bg-white/5 hover:text-cyan-400"
                >
                  {link.label}
                </a>
              ))
            }
          </div>
          <div class="mt-2.5 flex flex-col gap-3 border-t border-white/10 pt-3">
            <div>
              <span class="mb-1.5 block px-2 text-[10px] font-medium uppercase tracking-wider text-white/40">
                {m.nav.language}
              </span>
              <LanguageSwitcher variant="menu" languageLabel={m.nav.language} />
            </div>
            <a
              href={SHOP_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="flex w-full items-center justify-center rounded-full border border-accent/60 bg-accent/10 px-4 py-2.5 text-sm font-medium text-accent transition hover:bg-accent hover:text-white"
            >
              {m.nav.shop}
            </a>
          </div>
        </div>
      </details>
    </div>
  </div>
</header>
