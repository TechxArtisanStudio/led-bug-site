---
import { locales, localeMeta, type Locale } from '../i18n/locales';
import { getLocaleFromPath } from '../lib/locale-from-path';
import { localePath, stripLocalePath } from '../i18n/locales';

const current = getLocaleFromPath(Astro.url.pathname);
const basePath = stripLocalePath(Astro.url.pathname);
---

<div class="relative">
  <label for="lang-switcher" class="sr-only">Language</label>
  <select
    id="lang-switcher"
    class="max-w-[11rem] cursor-pointer rounded-lg border border-white/10 bg-bg/80 px-2 py-1.5 font-mono text-xs text-white/70 outline-none transition hover:border-cyan-500/40 hover:text-cyan-300"
  >
    {
      locales.map((code) => {
        const target = localePath(code, basePath);
        return (
          <option value={target} selected={code === current}>
            {localeMeta[code as Locale].label}
          </option>
        );
      })
    }
  </select>
</div>

<script>
  const sel = document.getElementById('lang-switcher');
  sel?.addEventListener('change', () => {
    const url = (sel as HTMLSelectElement).value;
    if (url && url !== window.location.pathname) window.location.href = url;
  });
</script>
