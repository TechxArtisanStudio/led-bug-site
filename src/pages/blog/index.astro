---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageSection from '../../components/PageSection.astro';
import PostCard from '../../components/blog/PostCard.astro';
import { getCollection } from 'astro:content';
import { postSlug, postsForLocale } from '../../lib/posts';
import { img } from '../../lib/cdn';
import { getMessages } from '../../lib/i18n';
import { defaultLocale } from '../../i18n/locales';

const m = await getMessages(defaultLocale);
const b = m.blog;
const posts = postsForLocale(await getCollection('posts'), defaultLocale).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const cover = posts[0]?.data.cover ?? img('blog/coloured-towers/part-1-journey-in-colour-exhibition-01.webp');
---

<BaseLayout
  title={b.indexTitle}
  description={b.metaDescription}
  image={cover}
  imageAlt={b.imageAlt}
>
  <PageSection>
    <p class="font-mono text-xs uppercase tracking-widest text-cyan-400/80">{b.label}</p>
    <h1 class="mt-2 text-4xl font-bold text-white sm:text-5xl">{b.heading}</h1>
    <p class="mt-4 max-w-xl text-white/60">{b.intro}</p>

    <div class="mt-12 grid gap-6 sm:grid-cols-2">
      {
        posts.map((post) => (
          <PostCard
            slug={postSlug(post)}
            title={post.data.title}
            subtitle={post.data.subtitle}
            description={post.data.description}
            cover={post.data.cover}
            date={post.data.date}
            categories={post.data.categories}
          />
        ))
      }
    </div>
  </PageSection>
</BaseLayout>
